'<h4>Lsolve: </h4>
m = 250
n = 250
w = m/20
A = symmetric(n)
$Repeat{$Repeat{A.(i; j) = m*n*(1 - abs(i/m - j/n)*w) @ j = i : min(i + w; n)} @ i = 1 : m}
B = hp(A)
b = range(1; n; 1)/10 + 100
b_hp = hp(b)

x_std = lsolve(A; b)
x_hp = lsolve(B; b_hp)

r_std = norm(A*x_std - b)/norm(b)
r_hp = norm(B*x_hp - b_hp)/norm(b_hp)

'<h4>Clsolve: </h4>
n = 250
A = symmetric(n)
v = transp(hp([10000; 500; 250; 200; 100; 50; 25; 20; 15; 10; 5; 3; 2; 1]))
$Repeat{add(v; A; i; i) @ i = 1 : n}
B = hp(A)
b = range(1; n; 1)/10 + 100
b_hp = hp(b)
x_std = clsolve(A; b)
x_hp = clsolve(B; b_hp)

r_std = norm(A*x_std - b)/norm(b)
r_hp = norm(B*x_hp - b_hp)/norm(b_hp)

'<h4>Slsolve: </h4>
n = 1000
#hide
A = symmetric_hp(n)
b = range_hp(1; n; 1)/10 + 100
v = transp(hp([1000; 500; 250; 200; 100; 50; 25; 20; 15; 10; 5; 3; 2; 1]))
$Repeat{add(v; A; i; i) @ i = 1 : n}
#show
A
b
X = slsolve(A; b)
r = norm(A*X - b)/norm(b)

'<h4>Msolve: </h4>
n = 250
A = symmetric(n)
v = transp(hp([10000; 500; 250; 200; 100; 50; 25; 20; 15; 10; 5; 3; 2; 1]))
$Repeat{$Repeat{A.(i; j) = m*n*(1 - abs(i/m - j/n)*w) @ j = i : min(i + w; n)} @ i = 1 : m}
A_hp = hp(A)
B = matrix(n; 3)
$Repeat{$Repeat{B.(i; j) = i/10 + 100*j @ j = 1 : 3} @ i = 1 : n}
B_hp = hp(B)
X_std = msolve(A; B)
X_hp = msolve(A_hp; B_hp)

r_std = mnorm(A*X_std - B)/mnorm(B)
r_hp = mnorm(A_hp*X_hp - B_hp)/mnorm(B_hp)

'<h4>Cmsolve: </h4>
n = 250
A = symmetric(n)
v = transp(hp([10000; 500; 250; 200; 100; 50; 25; 20; 15; 10; 5; 3; 2; 1]))
$Repeat{add(v; A; i; i) @ i = 1 : n}
A_hp = hp(A)
B = matrix(n; 3)
$Repeat{$Repeat{B.(i; j) = i/10 + 100*j @ j = 1 : 3} @ i = 1 : n}
B_hp = hp(B)
X_std = cmsolve(A; B)
X_hp = cmsolve(A_hp; B_hp)

r_std = mnorm(A*X_std - B)/mnorm(B)
r_hp = mnorm(A_hp*X_hp - B_hp)/mnorm(B_hp)

'<h4>Smsolve: </h4>
n = 250
#hide
A = symmetric_hp(n)
b = range_hp(1; n; 1)/10 + 100
B = matrix_hp(n; 1)
$Repeat{B.(i; 1) = b.i @ i = 1 : n}
v = transp(hp([1000; 500; 250; 200; 100; 50; 25; 20; 15; 10; 5; 3; 2; 1]))
$Repeat{add(v; A; i; i) @ i = 1 : n}
#show
A
b
X = smsolve(A; B)
r = mnorm_1(A*X - B)/norm(b)