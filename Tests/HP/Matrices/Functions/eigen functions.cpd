m = 250
n = 250
w = m/20
A = symmetric(n)
$Repeat{$Repeat{A.(i; j) = m*n*(1 - abs(i/m - j/n)*w) @ j = i : min(i + w; n)} @ i = 1 : m}
B = hp(A)

λ_std = eigenvals(A; w)
λ_hp = eigenvals(B; w)


mnorm_e(λ_std - λ_hp)/(mnorm_e(λ_hp))'< 0.5%

λ_std = eigenvecs(A; w)
λ_hp = eigenvecs(B; w)

mnorm_e(λ_std - λ_hp)/(mnorm_e(λ_hp))'< 0.5%

λ_std = eigen(A; w)
λ_hp = eigen(B; w)

mnorm_e(λ_std - λ_hp)/(mnorm_e(λ_hp))'< 0.5%


